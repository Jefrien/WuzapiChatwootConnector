# Server
PORT=3000
NODE_ENV=development

# Wuzapi Configuration
WUZAPI_BASE_URL=https://wuz.jefrien.dev
WUZAPI_TOKEN=your_wuzapi_user_token

# Chatwoot Configuration
CHATWOOT_BASE_URL=https://chatwoot.yourdomain.com
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_INBOX_IDENTIFIER=your_inbox_identifier

# Connector Configuration
CONNECTOR_WEBHOOK_SECRET=optional_secret_for_chatwoot_webhook_verification
